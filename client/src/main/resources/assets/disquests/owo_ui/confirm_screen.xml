<owo-ui xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/wisp-forest/owo-lib/1.21/owo-ui.xsd">

    <components>
    <!-- Root: vertical flow, full screen, translucent background, centered -->
    <flow-layout direction="vertical" id="root">
        <sizing>
            <horizontal method="fill">100</horizontal>
            <vertical method="fill">100</vertical>
        </sizing>
        <surface>
            <vanilla-translucent/>
        </surface>
        <horizontal-alignment>center</horizontal-alignment>
        <vertical-alignment>center</vertical-alignment>

        <children>

            <!-- Panel with dark background -->
            <flow-layout direction="vertical" id="panel">
                <sizing>
                    <horizontal method="content"/>
                    <vertical method="content"/>
                </sizing>
                <surface>
                    <panel dark="true"/>
                </surface>
                <padding>
                    <all>12</all>
                </padding>
                <horizontal-alignment>center</horizontal-alignment>
                <gap>8</gap>

                <children>

                    <!-- Message label -->
                    <label id="message-label">
                        <text>Are you sure?</text>
                        <shadow>true</shadow>
                        <max-width>300</max-width>
                        <sizing>
                            <horizontal method="content"/>
                            <vertical method="content"/>
                        </sizing>
                    </label>

                    <!-- Button row -->
                    <flow-layout direction="horizontal" id="button-row">
                        <sizing>
                            <horizontal method="content"/>
                            <vertical method="content"/>
                        </sizing>
                        <gap>4</gap>
                        <children>
                            <button id="btn-yes">
                                <text>Yes</text>
                                <sizing>
                                    <horizontal method="fixed">60</horizontal>
                                    <vertical method="fixed">20</vertical>
                                </sizing>
                            </button>
                            <button id="btn-no">
                                <text>No</text>
                                <sizing>
                                    <horizontal method="fixed">60</horizontal>
                                    <vertical method="fixed">20</vertical>
                                </sizing>
                            </button>
                        </children>
                    </flow-layout>

                </children>
            </flow-layout>

        </children>
    </flow-layout>
    </components>

</owo-ui>
