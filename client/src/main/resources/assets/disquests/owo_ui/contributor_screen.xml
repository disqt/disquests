<owo-ui xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/wisp-forest/owo-lib/1.21/owo-ui.xsd">

    <components>
    <flow-layout direction="vertical" id="root">
        <sizing>
            <horizontal method="fill">100</horizontal>
            <vertical method="fill">100</vertical>
        </sizing>
        <surface>
            <vanilla-translucent/>
        </surface>
        <horizontal-alignment>center</horizontal-alignment>
        <padding>
            <all>0</all>
            <top>8</top>
        </padding>

        <children>

            <!-- Title -->
            <label id="title-label">
                <text>Contributors</text>
                <shadow>true</shadow>
                <sizing>
                    <horizontal method="content"/>
                    <vertical method="content"/>
                </sizing>
                <margins>
                    <bottom>6</bottom>
                </margins>
            </label>

            <!-- Pending requests section (hidden via zero-sizing when empty) -->
            <flow-layout direction="vertical" id="pending-section">
                <sizing>
                    <horizontal method="fill">85</horizontal>
                    <vertical method="content"/>
                </sizing>
                <gap>2</gap>
                <margins>
                    <bottom>6</bottom>
                </margins>
                <children>
                    <label id="pending-header">
                        <text>Pending Requests</text>
                        <shadow>true</shadow>
                        <color>#FFAA33</color>
                    </label>
                    <!-- Pending entries added programmatically -->
                    <flow-layout direction="vertical" id="pending-list">
                        <sizing>
                            <horizontal method="fill">100</horizontal>
                            <vertical method="content"/>
                        </sizing>
                        <surface>
                            <panel dark="true"/>
                        </surface>
                        <padding>
                            <all>4</all>
                        </padding>
                        <gap>2</gap>
                        <children/>
                    </flow-layout>
                </children>
            </flow-layout>

            <!-- Contributor list (scrollable) -->
            <scroll direction="vertical" id="contributor-scroll">
                <flow-layout direction="vertical" id="contributor-list">
                    <sizing>
                        <horizontal method="fill">100</horizontal>
                        <vertical method="content"/>
                    </sizing>
                    <gap>2</gap>
                </flow-layout>
                <sizing>
                    <horizontal method="fill">85</horizontal>
                    <vertical method="fill">60</vertical>
                </sizing>
                <surface>
                    <panel dark="true"/>
                </surface>
                <padding>
                    <all>4</all>
                </padding>
            </scroll>

            <!-- Empty label (shown when no contributors and no pending) -->
            <label id="empty-label">
                <text>No contributors yet</text>
                <shadow>true</shadow>
                <sizing>
                    <horizontal method="content"/>
                    <vertical method="content"/>
                </sizing>
                <margins>
                    <top>10</top>
                </margins>
            </label>

            <!-- Close button -->
            <flow-layout direction="horizontal" id="button-row">
                <sizing>
                    <horizontal method="content"/>
                    <vertical method="content"/>
                </sizing>
                <margins>
                    <top>4</top>
                    <bottom>4</bottom>
                </margins>
                <children>
                    <button id="btn-close">
                        <text>Close</text>
                        <sizing>
                            <horizontal method="fixed">70</horizontal>
                            <vertical method="fixed">20</vertical>
                        </sizing>
                    </button>
                </children>
            </flow-layout>

        </children>
    </flow-layout>
    </components>

</owo-ui>
