<owo-ui xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/wisp-forest/owo-lib/1.21/owo-ui.xsd">

    <components>
    <flow-layout direction="vertical" id="root">
        <sizing>
            <horizontal method="fill">100</horizontal>
            <vertical method="fill">100</vertical>
        </sizing>
        <surface>
            <vanilla-translucent/>
        </surface>
        <horizontal-alignment>center</horizontal-alignment>
        <padding>
            <all>0</all>
            <top>4</top>
        </padding>

        <children>

            <!-- Header row: back arrow + title + owner/visibility info -->
            <flow-layout direction="horizontal" id="header-row">
                <sizing>
                    <horizontal method="fill">85</horizontal>
                    <vertical method="content"/>
                </sizing>
                <vertical-alignment>center</vertical-alignment>
                <margins>
                    <bottom>4</bottom>
                </margins>
                <children>
                    <button id="btn-back">
                        <text>&lt;</text>
                        <sizing>
                            <horizontal method="fixed">20</horizontal>
                            <vertical method="fixed">20</vertical>
                        </sizing>
                    </button>
                    <label id="title-label">
                        <text>Quest</text>
                        <shadow>true</shadow>
                        <sizing>
                            <horizontal method="expand">100</horizontal>
                            <vertical method="content"/>
                        </sizing>
                        <margins>
                            <left>4</left>
                        </margins>
                    </label>
                </children>
            </flow-layout>

            <!-- Tags collapsible slot (replaced programmatically with CollapsibleContainer) -->
            <flow-layout direction="horizontal" id="tag-display-slot">
                <sizing>
                    <horizontal method="fixed">0</horizontal>
                    <vertical method="fixed">0</vertical>
                </sizing>
                <children/>
            </flow-layout>

            <!-- Content scroll area (MarkdownWidget added programmatically) -->
            <template name="scrollable-list@disquests:templates">
                <scroll-id>content-scroll</scroll-id>
                <list-id>content-area</list-id>
                <width>85</width>
                <height>55</height>
            </template>

            <!-- Metadata row (coords, map, BlueMap button, hidden when no coords) -->
            <flow-layout direction="horizontal" id="metadata-row">
                <sizing>
                    <horizontal method="fill">85</horizontal>
                    <vertical method="content"/>
                </sizing>
                <surface>
                    <panel dark="true"/>
                </surface>
                <padding>
                    <all>4</all>
                </padding>
                <vertical-alignment>center</vertical-alignment>
                <gap>8</gap>
                <margins>
                    <top>2</top>
                </margins>
                <children>
                    <label id="coords-label">
                        <text></text>
                        <shadow>true</shadow>
                    </label>
                    <label id="map-label">
                        <text></text>
                        <shadow>true</shadow>
                    </label>
                </children>
            </flow-layout>

            <!-- Contributors collapsible slot (replaced programmatically with CollapsibleContainer) -->
            <flow-layout direction="horizontal" id="contributors-row-slot">
                <sizing>
                    <horizontal method="fixed">0</horizontal>
                    <vertical method="fixed">0</vertical>
                </sizing>
                <children/>
            </flow-layout>

            <!-- Button row -->
            <flow-layout direction="horizontal" id="button-row">
                <sizing>
                    <horizontal method="content"/>
                    <vertical method="content"/>
                </sizing>
                <gap>4</gap>
                <margins>
                    <top>4</top>
                    <bottom>4</bottom>
                </margins>
                <children>
                    <button id="btn-interact">
                        <text>Join</text>
                        <sizing>
                            <horizontal method="fixed">70</horizontal>
                            <vertical method="fixed">20</vertical>
                        </sizing>
                    </button>
                    <button id="btn-edit">
                        <text>Edit</text>
                        <sizing>
                            <horizontal method="fixed">60</horizontal>
                            <vertical method="fixed">20</vertical>
                        </sizing>
                    </button>
                    <button id="btn-leave">
                        <text>Leave</text>
                        <sizing>
                            <horizontal method="fixed">60</horizontal>
                            <vertical method="fixed">20</vertical>
                        </sizing>
                    </button>
                    <button id="btn-delete">
                        <text>Delete</text>
                        <sizing>
                            <horizontal method="fixed">60</horizontal>
                            <vertical method="fixed">20</vertical>
                        </sizing>
                    </button>
                </children>
            </flow-layout>

        </children>
    </flow-layout>
    </components>

</owo-ui>
