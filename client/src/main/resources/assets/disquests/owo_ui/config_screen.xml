<owo-ui xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/wisp-forest/owo-lib/1.21/owo-ui.xsd">

    <components>
    <flow-layout direction="vertical" id="root">
        <sizing>
            <horizontal method="fill">100</horizontal>
            <vertical method="fill">100</vertical>
        </sizing>
        <surface>
            <vanilla-translucent/>
        </surface>
        <horizontal-alignment>center</horizontal-alignment>
        <vertical-alignment>center</vertical-alignment>

        <children>

            <!-- Panel -->
            <flow-layout direction="vertical" id="panel">
                <sizing>
                    <horizontal method="content"/>
                    <vertical method="content"/>
                </sizing>
                <surface>
                    <panel dark="true"/>
                </surface>
                <padding>
                    <all>12</all>
                </padding>
                <horizontal-alignment>center</horizontal-alignment>
                <gap>8</gap>

                <children>

                    <!-- Title -->
                    <label id="title-label">
                        <text>Configuration</text>
                        <shadow>true</shadow>
                        <sizing>
                            <horizontal method="content"/>
                            <vertical method="content"/>
                        </sizing>
                    </label>

                    <!-- Theme selector -->
                    <flow-layout direction="horizontal" id="theme-row">
                        <sizing>
                            <horizontal method="content"/>
                            <vertical method="content"/>
                        </sizing>
                        <vertical-alignment>center</vertical-alignment>
                        <gap>8</gap>
                        <children>
                            <label id="theme-label">
                                <text>Theme:</text>
                                <shadow>true</shadow>
                            </label>
                            <button id="btn-theme">
                                <text>Vanilla</text>
                                <sizing>
                                    <horizontal method="fixed">100</horizontal>
                                    <vertical method="fixed">20</vertical>
                                </sizing>
                            </button>
                        </children>
                    </flow-layout>

                    <!-- Slider placeholder - added programmatically -->
                    <flow-layout direction="horizontal" id="slider-row">
                        <sizing>
                            <horizontal method="content"/>
                            <vertical method="content"/>
                        </sizing>
                        <vertical-alignment>center</vertical-alignment>
                        <gap>8</gap>
                        <children>
                            <label id="slider-label">
                                <text>Pinned Width:</text>
                                <shadow>true</shadow>
                            </label>
                        </children>
                    </flow-layout>

                    <!-- Button row -->
                    <flow-layout direction="horizontal" id="button-row">
                        <sizing>
                            <horizontal method="content"/>
                            <vertical method="content"/>
                        </sizing>
                        <gap>4</gap>
                        <children>
                            <button id="btn-save">
                                <text>Save</text>
                                <sizing>
                                    <horizontal method="fixed">60</horizontal>
                                    <vertical method="fixed">20</vertical>
                                </sizing>
                            </button>
                            <button id="btn-cancel">
                                <text>Cancel</text>
                                <sizing>
                                    <horizontal method="fixed">60</horizontal>
                                    <vertical method="fixed">20</vertical>
                                </sizing>
                            </button>
                        </children>
                    </flow-layout>

                </children>
            </flow-layout>

        </children>
    </flow-layout>
    </components>

</owo-ui>
